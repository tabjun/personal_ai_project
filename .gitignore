# .gitignore (루트용)

# 가상환경 폴더 무시
.venv/
venv/
env/

# 환경변수 및 키 파일 무시 (보안)
.env
*.ini
*.key
*.db*
*.pdf
*.hwp
*.docs
*.xls*

# 파이썬 캐시 무시
__pycache__/
*.pyc
build/
dist/
wheels/
*.egg-info
*.python-version
.DS_Store

# VS Code 설정 무시
.vscode/
resume.pdf

#  [개인정보 보호] 
result/
# 2. more_info 폴더 내부는 전부 무시하되 특정 파일만 예외
resum/more_info/*
!resum/more_info/guideline.txt

# 3. knowledge 폴더 내부는 전부 무시하되 특정 파일만 예외
resum/knowledge/*
!resum/knowledge/resume_example.md
!resum/knowledge/resume_example.txt
